@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MANIT SOLUTIONS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #1a3a6b 0%, #2563eb 50%, #1d4ed8 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: #fff;
            border-radius: 16px;
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        .brand {
            text-align: center;
            margin-bottom: 2rem;
        }
        .brand h2 {
            color: #1a3a6b;
            font-weight: 700;
            font-size: 1.75rem;
            margin-bottom: 0.25rem;
        }
        .brand p {
            color: #6b7280;
            font-size: 0.9rem;
            margin: 0;
        }
        .form-label {
            font-weight: 600;
            color: #374151;
            font-size: 0.875rem;
        }
        .form-control {
            border-radius: 10px;
            padding: 0.65rem 1rem;
            border: 1.5px solid #d1d5db;
        }
        .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }
        .btn-login {
            background: #1a3a6b;
            border: none;
            border-radius: 10px;
            padding: 0.7rem;
            font-weight: 600;
            font-size: 1rem;
            width: 100%;
            color: #fff;
            transition: background 0.2s;
        }
        .btn-login:hover {
            background: #2563eb;
        }
        .alert {
            border-radius: 10px;
            font-size: 0.9rem;
        }
        .demo-hint {
            text-align: center;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e5e7eb;
            color: #9ca3af;
            font-size: 0.8rem;
        }
        .demo-hint code {
            background: #f3f4f6;
            padding: 2px 8px;
            border-radius: 4px;
            color: #374151;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <div class="brand">
                <h2>MANIT SOLUTIONS</h2>
                <p>Payroll Management System</p>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger" role="alert">
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="Login">
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input type="text" class="form-control" id="username" name="username"
                           placeholder="Enter your username" required autofocus />
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password" name="password"
                           placeholder="Enter your password" required />
                </div>
                <button type="submit" class="btn-login">Sign In</button>
            </form>

            <div class="demo-hint">
                Demo: <code>admin</code> / <code>admin</code>
            </div>
        </div>
    </div>
</body>
</html>

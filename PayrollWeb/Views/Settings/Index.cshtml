@model CompanySetting
@{
    ViewData["Title"] = "Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold" style="color: #0F1B3D;">Company Settings</h4>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle me-1"></i> @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4" style="max-width: 800px; margin: 0 auto;">
    <div class="card-body p-4">
        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()

            <h5 class="fw-bold mb-3" style="color: #0F1B3D;">Company Information</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="CompanyName" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="CompanyName" class="form-control" />
                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="GstNo" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="GstNo" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label small fw-medium text-muted"></label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="FounderName" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="FounderName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="CeoName" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="CeoName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactNo" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="ContactNo" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EmailId" class="form-label small fw-medium text-muted"></label>
                    <input asp-for="EmailId" class="form-control" />
                </div>
            </div>

            <h5 class="fw-bold mb-3" style="color: #0F1B3D;">Payroll Deductions</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="PfPercentage" class="form-label small fw-medium text-muted">PF (%)</label>
                    <input asp-for="PfPercentage" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="PfPercentage" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EsicPercentage" class="form-label small fw-medium text-muted">ESIC (%)</label>
                    <input asp-for="EsicPercentage" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="EsicPercentage" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-3 px-4">
                    <i class="bi bi-save me-1"></i> Save Settings
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

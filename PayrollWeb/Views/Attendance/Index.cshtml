@model List<AttendanceRow>
@{
    ViewData["Title"] = "Daily Attendance";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold" style="color: #0F1B3D;">Daily Attendance</h4>
    <a asp-action="Monthly" asp-route-year="@DateTime.Now.Year" asp-route-month="@DateTime.Now.Month"
       class="btn btn-outline-primary rounded-3 px-4">
        <i class="bi bi-calendar-month me-1"></i> Monthly View
    </a>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle me-1"></i> @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Date Picker & Mark All Present -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small fw-medium text-muted">Select Date</label>
                        <input type="date" name="date" class="form-control form-control-sm"
                               value="@ViewBag.SelectedDate" max="@ViewBag.TodayDate" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary btn-sm px-3 rounded-3 mt-4">
                            <i class="bi bi-search me-1"></i> Load
                        </button>
                    </div>
                </form>
            </div>
            <div class="col-md-7 text-md-end mt-3 mt-md-0">
                <form method="post" asp-action="MarkAllPresent" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="date" value="@ViewBag.SelectedDate" />
                    <button type="submit" class="btn btn-success btn-sm px-3 rounded-3"
                            onclick="return confirm('Mark ALL employees as Present for @ViewBag.SelectedDate?');">
                        <i class="bi bi-check-all me-1"></i> Mark All Present
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Attendance Table -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Employee Code</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th style="width:280px;">Mark Attendance</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        foreach (var row in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@row.EmployeeCode</td>
                                <td>@row.EmployeeName</td>
                                <td>@row.Department</td>
                                <td>
                                    @switch (row.Status)
                                    {
                                        case "P":
                                            <span class="badge bg-success rounded-pill">Present</span>
                                            break;
                                        case "A":
                                            <span class="badge bg-danger rounded-pill">Absent</span>
                                            break;
                                        case "L":
                                            <span class="badge bg-warning text-dark rounded-pill">Leave</span>
                                            break;
                                        case "WO":
                                            <span class="badge bg-secondary rounded-pill">Weekly Off</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-muted rounded-pill border">Not Marked</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <form method="post" asp-action="MarkAttendance" class="row g-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="employeeCode" value="@row.EmployeeCode" />
                                        <input type="hidden" name="date" value="@ViewBag.SelectedDate" />
                                        <div class="col-auto">
                                            <select name="status" class="form-select form-select-sm">
                                                <option value="P" selected="@(row.Status == "P")">Present</option>
                                                <option value="A" selected="@(row.Status == "A")">Absent</option>
                                                <option value="L" selected="@(row.Status == "L")">Leave</option>
                                                <option value="WO" selected="@(row.Status == "WO")">Weekly Off</option>
                                            </select>
                                        </div>
                                        <div class="col-auto">
                                            <button type="submit" class="btn btn-sm btn-primary rounded-3">
                                                <i class="bi bi-save me-1"></i> Save
                                            </button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-people fs-2 d-block mb-2 text-secondary"></i>
                                No employees found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

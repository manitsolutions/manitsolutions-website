@model List<Employee>
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold" style="color: #0F1B3D;">Employees</h4>
    <a asp-action="Create" class="btn btn-primary rounded-3 px-4">
        <i class="bi bi-plus-lg me-1"></i> Add Employee
    </a>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle me-1"></i> @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search / Filter -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small fw-medium text-muted">Search by Name or Code</label>
                <input type="text" name="searchName" class="form-control form-control-sm" placeholder="Search..."
                       value="@ViewBag.SearchName" />
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-medium text-muted">Department</label>
                <select name="searchDepartment" class="form-select form-select-sm">
                    <option value="">All Departments</option>
                    @if (ViewBag.Departments is List<Department> depts)
                    {
                        foreach (var d in depts)
                        {
                            <option value="@d.Id" selected="@(ViewBag.SearchDepartment?.Equals(d.Id) == true)">
                                @d.Name
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm px-3 rounded-3">
                    <i class="bi bi-filter me-1"></i> Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 rounded-3">
                    <i class="bi bi-arrow-counterclockwise"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Employee Table -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Code</th>
                        <th>Name</th>
                        <th>Department</th>
                        <th>Sub Department</th>
                        <th>Designation</th>
                        <th>Status</th>
                        <th class="text-center" style="width:120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        foreach (var emp in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">@emp.EmployeeCode</td>
                                <td>@emp.EmployeeName</td>
                                <td>@emp.Department?.Name</td>
                                <td>@emp.SubDepartment?.Name</td>
                                <td>@emp.Designation</td>
                                <td>
                                    <span class="badge @(emp.Status == "Active" ? "bg-success" : "bg-secondary") rounded-pill">
                                        @emp.Status
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@emp.Id"
                                       class="btn btn-sm btn-outline-primary rounded-3 me-1" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@emp.Id" method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Delete employee @emp.EmployeeName?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-5">
                                <i class="bi bi-people fs-2 d-block mb-2 text-secondary"></i>
                                No employees found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

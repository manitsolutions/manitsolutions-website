@model List<SalaryRecord>
@{
    ViewData["Title"] = "Salary";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold" style="color: #0F1B3D;">Salary Records</h4>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-check-circle me-1"></i> @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Year / Month Selector & Generate -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small fw-medium text-muted">Year</label>
                        <select name="year" class="form-select form-select-sm">
                            @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                            {
                                <option value="@y" selected="@(y == ViewBag.Year)">@y</option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label small fw-medium text-muted">Month</label>
                        <select name="month" class="form-select form-select-sm">
                            @for (int m = 1; m <= 12; m++)
                            {
                                <option value="@m" selected="@(m == ViewBag.Month)">
                                    @(new DateTime(2000, m, 1).ToString("MMMM"))
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary btn-sm px-3 rounded-3 mt-4">
                            <i class="bi bi-search me-1"></i> Load
                        </button>
                    </div>
                </form>
            </div>
            <div class="col-md-7 text-md-end mt-3 mt-md-0">
                <form method="post" asp-action="GenerateSalary" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="year" value="@ViewBag.Year" />
                    <input type="hidden" name="month" value="@ViewBag.Month" />
                    <button type="submit" class="btn btn-success btn-sm px-3 rounded-3"
                            onclick="return confirm('Generate / regenerate salary for all active employees for @ViewBag.Month/@ViewBag.Year? Existing records will be updated.');">
                        <i class="bi bi-calculator me-1"></i> Generate Salary
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Salary Table -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Employee</th>
                        <th class="text-end">Basic</th>
                        <th class="text-end">DA</th>
                        <th class="text-end">Gross</th>
                        <th class="text-end">PF</th>
                        <th class="text-end">ESIC</th>
                        <th class="text-end">PT</th>
                        <th class="text-end">Net</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width:160px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count > 0)
                    {
                        foreach (var rec in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-medium">@rec.EmployeeName</div>
                                    <small class="text-muted">@rec.EmployeeCode | @rec.Department</small>
                                </td>
                                <td class="text-end">@rec.BasicSalary.ToString("N2")</td>
                                <td class="text-end">@rec.Da.ToString("N2")</td>
                                <td class="text-end">@rec.GrossSalary.ToString("N2")</td>
                                <td class="text-end">@rec.Pf.ToString("N2")</td>
                                <td class="text-end">@rec.Esic.ToString("N2")</td>
                                <td class="text-end">@rec.Pt.ToString("N2")</td>
                                <td class="text-end fw-bold">@rec.NetSalary.ToString("N2")</td>
                                <td class="text-center">
                                    @if (rec.IsPaid)
                                    {
                                        <span class="badge bg-success rounded-pill">Paid</span>
                                    }
                                    else if (rec.IsUnpaid)
                                    {
                                        <span class="badge bg-danger rounded-pill">Unpaid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!rec.IsPaid)
                                    {
                                        <form method="post" asp-action="MarkPaid" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@rec.Id" />
                                            <input type="hidden" name="year" value="@ViewBag.Year" />
                                            <input type="hidden" name="month" value="@ViewBag.Month" />
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-3 me-1"
                                                    title="Mark Paid">
                                                <i class="bi bi-check-lg"></i> Paid
                                            </button>
                                        </form>
                                    }
                                    @if (!rec.IsUnpaid)
                                    {
                                        <form method="post" asp-action="MarkUnpaid" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@rec.Id" />
                                            <input type="hidden" name="year" value="@ViewBag.Year" />
                                            <input type="hidden" name="month" value="@ViewBag.Month" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-3"
                                                    title="Mark Unpaid">
                                                <i class="bi bi-x-lg"></i> Unpaid
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="bi bi-cash-stack fs-2 d-block mb-2 text-secondary"></i>
                                No salary records for @ViewBag.Month/@ViewBag.Year.
                                Click <strong>"Generate Salary"</strong> above to create records.
                            </td>
                        </tr>
                    }
                </tbody>
                @if (Model.Count > 0)
                {
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td class="ps-4">Totals</td>
                            <td class="text-end">@Model.Sum(r => r.BasicSalary).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.Da).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.GrossSalary).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.Pf).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.Esic).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.Pt).ToString("N2")</td>
                            <td class="text-end">@Model.Sum(r => r.NetSalary).ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                        <tr>
                            <td colspan="7"></td>
                            <td colspan="3">
                                <span class="text-success">Paid: @ViewBag.TotalPaid.ToString("N2")</span> &middot;
                                <span class="text-danger">Unpaid: @ViewBag.TotalUnpaid.ToString("N2")</span>
                            </td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>
